---
import BaseLayout from './BaseLayout.astro';
import SectionLabel from '@/components/astro/SectionLabel.astro';
import TechTag from '@/components/astro/TechTag.astro';
import { ExternalLink } from '@lucide/astro';
import '@/styles/typography.css';

interface Props {
  title: string;
  description: string;
  year: number;
  role: string;
  technologies: string[];
  github?: string;
  demo?: string;
}

const { title, description, year, role, technologies, github, demo } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <article class="project-page">
    <div class="container">

      <!-- 01 // PROJE -->
      <header class="project-header">
        <SectionLabel number="01" label="Proje" />
        <h1 class="project-hero-title">{title}</h1>

        <div class="project-meta-grid">
          <div class="project-meta-item">
            <span class="project-meta-label">Yıl</span>
            <span class="project-meta-value">{year}</span>
          </div>
          <div class="project-meta-item">
            <span class="project-meta-label">Rol</span>
            <span class="project-meta-value">{role}</span>
          </div>
          <div class="project-meta-item project-meta-item--wide">
            <span class="project-meta-label">Teknolojiler</span>
            <div class="project-meta-tags">
              {technologies.map((tech) => <TechTag label={tech} />)}
            </div>
          </div>
        </div>

        <!-- GitHub / Demo linkleri -->
        {(github || demo) && (
          <div class="project-links">
            {github && (
              <a
                href={github}
                target="_blank"
                rel="noopener noreferrer"
                class="project-ext-link"
              >
                <!-- GitHub SVG (Lucide'da yok, inline) -->
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.2c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.4 5.4 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/>
                </svg>
                <span>GitHub</span>
              </a>
            )}
            {demo && (
              <a
                href={demo}
                target="_blank"
                rel="noopener noreferrer"
                class="project-ext-link"
              >
                <ExternalLink size={14} strokeWidth={1.5} />
                <span>Demo</span>
              </a>
            )}
          </div>
        )}
      </header>

      <!-- MDX içerik (02 // PROBLEM → 06 // ÖĞRENDİKLERİM) -->
      <div class="prose project-content">
        <slot />
      </div>

      <!-- Alt: Geri dön -->
      <footer class="project-footer">
        <a href="/projeler" class="project-back">
          ← Tüm çalışmalar
        </a>
      </footer>

    </div>
  </article>
</BaseLayout>

<style>
  .project-page {
    padding-block: var(--space-12) var(--space-section-mobile);
  }

  @media (min-width: 1024px) {
    .project-page {
      padding-block: var(--space-12) var(--space-section-desktop);
    }
  }

  /* Header */
  .project-header {
    max-width: 860px;
    margin-bottom: var(--space-12);
    padding-bottom: var(--space-10);
    border-bottom: 1px solid var(--border);
  }

  .project-hero-title {
    font-size: clamp(2rem, 4vw + 0.5rem, 3rem);
    letter-spacing: var(--tracking-tight);
    line-height: var(--leading-tight);
    color: var(--text);
    margin-bottom: var(--space-8);
    max-width: 22ch;
  }

  /* Meta grid */
  .project-meta-grid {
    display: grid;
    grid-template-columns: repeat(3, auto);
    gap: var(--space-8) var(--space-10);
    margin-bottom: var(--space-8);
    align-items: start;
    justify-content: start;
  }

  @media (max-width: 640px) {
    .project-meta-grid {
      grid-template-columns: 1fr;
      gap: var(--space-6);
    }
  }

  .project-meta-item--wide {
    grid-column: 1 / -1;
  }

  .project-meta-label {
    display: block;
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--text-faint);
    margin-bottom: var(--space-2);
    line-height: 1;
  }

  .project-meta-value {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--text);
    letter-spacing: 0.02em;
  }

  .project-meta-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  /* Dış linkler */
  .project-links {
    display: flex;
    gap: var(--space-4);
  }

  .project-ext-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-muted);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 0.5rem 0.875rem;
    transition: color var(--duration-fast) var(--ease-out),
                border-color var(--duration-fast) var(--ease-out);
  }

  .project-ext-link:hover {
    color: var(--accent);
    border-color: var(--accent);
  }

  .project-ext-link:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  /* MDX içerik */
  .project-content {
    max-width: 72ch;
  }

  /* MDX h2 → section label hissi, CSS counter ile numaralandırma */
  .project-content {
    counter-reset: section 1;
  }

  .project-content :global(h2) {
    font-size: var(--text-xl);
    font-weight: 600;
    letter-spacing: var(--tracking-tight);
    color: var(--text);
    margin-top: 3em;
    margin-bottom: 1em;
    padding-top: var(--space-8);
    border-top: 1px solid var(--border);
    counter-increment: section;
  }

  .project-content :global(h2)::before {
    display: block;
    content: '0' counter(section) ' //';
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 400;
    color: var(--accent);
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    margin-bottom: var(--space-3);
    line-height: 1;
  }

  /* Tablo — metrik tabloları için */
  .project-content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 2em 0;
    font-size: var(--text-sm);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .project-content :global(th) {
    text-align: left;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-muted);
    background: var(--bg-subtle);
    border-bottom: 1px solid var(--border);
    padding: var(--space-3) var(--space-4);
  }

  .project-content :global(td) {
    border-bottom: 1px solid var(--border);
    padding: var(--space-3) var(--space-4);
    color: var(--text-muted);
    font-size: var(--text-sm);
  }

  .project-content :global(tr:last-child td) {
    border-bottom: none;
  }

  /* Footer */
  .project-footer {
    margin-top: var(--space-12);
    padding-top: var(--space-8);
    border-top: 1px solid var(--border);
  }

  .project-back {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.06em;
    color: var(--text-muted);
    transition: color var(--duration-fast) var(--ease-out);
  }

  .project-back:hover {
    color: var(--accent);
  }
</style>
