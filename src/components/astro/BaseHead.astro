---
import { site } from '@/data/site';
import '@/styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  canonicalURL?: string;
  schema?: Record<string, unknown> | null;
  ogType?: 'website' | 'article';
  robots?: string;
  publishedTime?: string;
  keywords?: string;
}

const {
  title,
  description = site.bio,
  ogImage = '/og-default.png',
  canonicalURL = new URL(Astro.url.pathname, site.url).href,
  schema = null,
  ogType = 'website',
  robots = 'index, follow',
  publishedTime,
  keywords,
} = Astro.props;

const pageTitle = title ? `${title} — ${site.name}` : `${site.name} — ${site.role}`;
const ogImageURL = new URL(ogImage, site.url).href;
const twitterHandle = site.social.x.replace('https://x.com/', '@');
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="generator" content={Astro.generator} />
<meta name="google-site-verification" content="ybcaypPp93u_QNhdLye3H7n8J1eN2k3XTEL89L3q1E8" />
<meta name="robots" content={robots} />
<meta name="author" content={site.name} />
{keywords && <meta name="keywords" content={keywords} />}
<meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)" />
<meta name="theme-color" content="#0a0a0a" media="(prefers-color-scheme: dark)" />

<!-- Favicon -->
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />

<!-- Primary Meta -->
<title>{pageTitle}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalURL} />

<!-- Open Graph -->
<meta property="og:type" content={ogType} />
<meta property="og:title" content={pageTitle} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:image" content={ogImageURL} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:locale" content="tr_TR" />
<meta property="og:site_name" content={site.name} />
{ogType === 'article' && publishedTime && (
  <meta property="article:published_time" content={publishedTime} />
)}
{ogType === 'article' && (
  <meta property="article:author" content={site.url} />
)}

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:site" content={twitterHandle} />
<meta name="twitter:creator" content={twitterHandle} />
<meta name="twitter:title" content={pageTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageURL} />

<!-- JSON-LD -->
{schema && (
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
)}

<!-- FOUC önleme: tema inline script -->
<script is:inline>
  (function () {
    const stored = localStorage.getItem('theme');
    const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
    const theme = stored ?? (prefersDark ? 'dark' : 'light');
    document.documentElement.setAttribute('data-theme', theme);
  })();
</script>
