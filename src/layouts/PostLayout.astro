---
import BaseLayout from './BaseLayout.astro';
import TableOfContents from '@/components/react/TableOfContents';
import { site } from '@/data/site';
import { formatDate } from '@/lib/utils';
import '@/styles/typography.css';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  title: string;
  description: string;
  date: Date;
  category: string;
  tags: string[];
  readingTime: string;
  headings: Heading[];
  relatedPosts?: {
    slug: string;
    title: string;
    category: string;
    date: Date;
  }[];
}

const {
  title,
  description,
  date,
  category,
  tags,
  readingTime,
  headings,
  relatedPosts = [],
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, site.url).href;

const blogPostingSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description,
  datePublished: date.toISOString(),
  author: {
    '@type': 'Person',
    name: site.name,
    url: site.url,
  },
  publisher: {
    '@type': 'Person',
    name: site.name,
    url: site.url,
  },
  url: canonicalURL,
  keywords: tags.join(', '),
  articleSection: category,
  inLanguage: 'tr',
};
---

<BaseLayout title={title} description={description} schema={blogPostingSchema}>
  <article class="post-page">
    <div class="container">
      <div class="post-layout">

        <!-- Ana içerik -->
        <div class="post-main">
          <!-- Meta üst -->
          <header class="post-header">
            <div class="post-meta">
              <span class="post-category">{category}</span>
              <span class="post-meta-sep">·</span>
              <time datetime={date.toISOString()} class="post-date">{formatDate(date)}</time>
              <span class="post-meta-sep">·</span>
              <span class="post-reading">{readingTime}</span>
            </div>
            <h1 class="post-title">{title}</h1>
            <p class="post-description">{description}</p>

            {tags.length > 0 && (
              <div class="post-tags">
                {tags.map((tag) => (
                  <span class="post-tag">#{tag}</span>
                ))}
              </div>
            )}
          </header>

          <!-- MDX içerik -->
          <div class="prose post-content" id="post-content">
            <slot />
          </div>

          <!-- Yazar kartı -->
          <footer class="post-author">
            <div class="post-author__inner">
              <div class="post-author__info">
                <p class="post-author__name">{site.name}</p>
                <p class="post-author__role">{site.role}</p>
              </div>
              <div class="post-author__social">
                <a
                  href={site.social.linkedin}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="post-author__link"
                  aria-label="LinkedIn"
                >
                  LinkedIn
                </a>
                <a
                  href={site.social.x}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="post-author__link"
                  aria-label="X (Twitter)"
                >
                  X
                </a>
              </div>
            </div>
          </footer>

          <!-- İlgili yazılar -->
          {relatedPosts.length > 0 && (
            <section class="post-related">
              <p class="post-related__label">
                <span class="post-related__accent">//</span> İlgili Yazılar
              </p>
              <div class="post-related__list">
                {relatedPosts.slice(0, 2).map((post) => (
                  <a href={`/blog/${post.slug}`} class="post-related__item">
                    <span class="post-related__cat">{post.category}</span>
                    <span class="post-related__title">{post.title}</span>
                  </a>
                ))}
              </div>
            </section>
          )}
        </div>

        <!-- TOC kenar çubuğu -->
        <aside class="post-toc">
          <div class="post-toc__sticky">
            <TableOfContents headings={headings} client:visible />
          </div>
        </aside>

      </div>
    </div>
  </article>
</BaseLayout>

<!-- Kod bloklarına kopyala düğmesi ve dil etiketi enjekte et -->
<script>
  function enhanceCodeBlocks() {
    document.querySelectorAll('#post-content pre.astro-code').forEach((pre) => {
      if (pre.closest('.code-block-wrapper')) return;

      const wrapper = document.createElement('div');
      wrapper.className = 'code-block-wrapper';
      pre.parentNode?.insertBefore(wrapper, pre);
      wrapper.appendChild(pre);

      // Dil etiketi
      const lang = pre.getAttribute('data-language');
      if (lang) {
        const langEl = document.createElement('span');
        langEl.className = 'code-lang';
        langEl.textContent = lang;
        wrapper.appendChild(langEl);
      }

      // Kopyala düğmesi
      const code = pre.querySelector('code')?.textContent ?? '';
      const btn = document.createElement('button');
      btn.className = 'copy-btn';
      btn.setAttribute('aria-label', 'Kopyala');
      btn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>`;

      btn.addEventListener('click', async () => {
        try {
          await navigator.clipboard.writeText(code);
          btn.classList.add('copied');
          btn.setAttribute('aria-label', 'Kopyalandı');
          btn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>`;
          setTimeout(() => {
            btn.classList.remove('copied');
            btn.setAttribute('aria-label', 'Kopyala');
            btn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>`;
          }, 2000);
        } catch {}
      });

      wrapper.appendChild(btn);
    });
  }

  enhanceCodeBlocks();
  document.addEventListener('astro:page-load', enhanceCodeBlocks);
</script>

<style>
  .post-page {
    padding-block: var(--space-12) var(--space-section-mobile);
  }

  @media (min-width: 1024px) {
    .post-page {
      padding-block: var(--space-12) var(--space-section-desktop);
    }
  }

  /* Layout: içerik + TOC */
  .post-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-12);
    max-width: 960px;
  }

  @media (min-width: 1024px) {
    .post-layout {
      grid-template-columns: 1fr 220px;
      max-width: 100%;
      align-items: start;
    }
  }

  /* Header */
  .post-header {
    margin-bottom: var(--space-12);
    padding-bottom: var(--space-10);
    border-bottom: 1px solid var(--border);
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-6);
    flex-wrap: wrap;
  }

  .post-category {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .post-meta-sep {
    color: var(--text-faint);
    font-size: var(--text-xs);
  }

  .post-date,
  .post-reading {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--text-faint);
    letter-spacing: 0.03em;
  }

  .post-title {
    font-size: clamp(2rem, 4vw + 0.5rem, 3rem);
    letter-spacing: var(--tracking-tight);
    line-height: var(--leading-tight);
    color: var(--text);
    margin-bottom: var(--space-6);
  }

  .post-description {
    font-size: var(--text-lg);
    color: var(--text-muted);
    line-height: var(--leading-relaxed);
    max-width: 60ch;
    margin-bottom: var(--space-6);
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .post-tag {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-faint);
    background: var(--bg-subtle);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 0.2em 0.5em;
  }

  /* İçerik */
  .post-content {
    max-width: var(--content-prose);
  }

  /* Yazar kartı */
  .post-author {
    margin-top: var(--space-12);
    padding-top: var(--space-8);
    border-top: 1px solid var(--border);
  }

  .post-author__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-6);
  }

  .post-author__name {
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--text);
    margin-bottom: 2px;
  }

  .post-author__role {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--text-faint);
    letter-spacing: 0.03em;
  }

  .post-author__social {
    display: flex;
    gap: var(--space-4);
  }

  .post-author__link {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-muted);
    transition: color var(--duration-fast) var(--ease-out);
  }

  .post-author__link:hover {
    color: var(--accent);
  }

  /* İlgili yazılar */
  .post-related {
    margin-top: var(--space-10);
  }

  .post-related__label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--text-faint);
    margin-bottom: var(--space-5);
    line-height: 1;
  }

  .post-related__accent {
    color: var(--accent);
  }

  .post-related__list {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4);
  }

  @media (max-width: 640px) {
    .post-related__list {
      grid-template-columns: 1fr;
    }
  }

  .post-related__item {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding: var(--space-5);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    transition: border-color var(--duration-fast) var(--ease-out),
                background-color var(--duration-fast) var(--ease-out);
  }

  .post-related__item:hover {
    border-color: var(--border-strong);
    background-color: var(--bg-subtle);
  }

  .post-related__cat {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .post-related__title {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--text);
    line-height: var(--leading-snug);
  }

  /* TOC sidebar */
  .post-toc {
    display: none;
  }

  @media (min-width: 1024px) {
    .post-toc {
      display: block;
    }

    .post-toc__sticky {
      position: sticky;
      top: 6rem;
      max-height: calc(100vh - 8rem);
      overflow-y: auto;
      padding-right: var(--space-2);
    }
  }
</style>
