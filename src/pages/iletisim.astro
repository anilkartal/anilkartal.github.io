---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SectionLabel from '@/components/astro/SectionLabel.astro';
import CopyButton from '@/components/react/CopyButton';
import { site } from '@/data/site';
---

<BaseLayout
  title="İletişim"
  description="Yazışmak, iş birliği yapmak veya fikir paylaşmak için iletişime geçin."
>
  <section class="contact-page">
    <div class="container">

      <SectionLabel number="00" label="İletişim" />
      <h1 class="contact-title">Yazın</h1>
      <p class="contact-sub">
        Test otomasyonu, yazılım kalitesi veya mühendislik üzerine konuşmaktan mutluluk duyarım.
      </p>

      <!-- E-posta -->
      <div class="email-block">
        <p class="email-label">E-posta</p>
        <div class="email-row">
          <a href={`mailto:${site.email}`} class="email-address">
            {site.email}
          </a>
          <CopyButton text={site.email} client:load />
        </div>
      </div>

      <!-- Sosyal linkler -->
      <div class="social-block">
        <p class="social-label">Sosyal</p>
        <ul class="social-list">

          <!-- GitHub -->
          <li>
            <a
              href={site.social.github}
              target="_blank"
              rel="noopener noreferrer"
              class="social-link"
            >
              <span class="social-icon" aria-hidden="true">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.2c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.4 5.4 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/>
                  <path d="M9 18c-4.51 2-5-2-7-2"/>
                </svg>
              </span>
              <span class="social-name">GitHub</span>
              <span class="social-handle">@{site.social.github.split('/').pop()}</span>
            </a>
          </li>

          <!-- LinkedIn -->
          <li>
            <a
              href={site.social.linkedin}
              target="_blank"
              rel="noopener noreferrer"
              class="social-link"
            >
              <span class="social-icon" aria-hidden="true">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
                  <rect width="4" height="12" x="2" y="9"/>
                  <circle cx="4" cy="4" r="2"/>
                </svg>
              </span>
              <span class="social-name">LinkedIn</span>
              <span class="social-handle">@{site.social.linkedin.split('/in/').pop()}</span>
            </a>
          </li>

          <!-- X / Twitter -->
          <li>
            <a
              href={site.social.x}
              target="_blank"
              rel="noopener noreferrer"
              class="social-link"
            >
              <span class="social-icon" aria-hidden="true">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M4 4l16 16M4 20L20 4"/>
                </svg>
              </span>
              <span class="social-name">X</span>
              <span class="social-handle">@{site.social.x.split('/').pop()}</span>
            </a>
          </li>

        </ul>
      </div>

    </div>
  </section>
</BaseLayout>

<style>
  .contact-page {
    padding-block: var(--space-12) var(--space-section-mobile);
  }

  @media (min-width: 1024px) {
    .contact-page {
      padding-block: var(--space-12) var(--space-section-desktop);
    }
  }

  .contact-title {
    font-size: clamp(2rem, 4vw + 0.5rem, 3.5rem);
    letter-spacing: var(--tracking-tight);
    color: var(--text);
    margin-top: var(--space-3);
    margin-bottom: var(--space-6);
  }

  .contact-sub {
    font-size: var(--text-lg);
    color: var(--text-muted);
    max-width: 48ch;
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-16);
  }

  /* ─── E-posta ─── */
  .email-block {
    margin-bottom: var(--space-12);
  }

  .email-label {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--text-faint);
    margin-bottom: var(--space-4);
    line-height: 1;
  }

  .email-row {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .email-address {
    font-family: var(--font-mono);
    font-size: clamp(1.25rem, 2vw + 0.5rem, 1.75rem);
    font-weight: 400;
    color: var(--text);
    letter-spacing: -0.01em;
    transition: color var(--duration-fast) var(--ease-out);
  }

  .email-address:hover {
    color: var(--accent);
  }

  /* ─── Sosyal ─── */
  .social-block {
    padding-top: var(--space-10);
    border-top: 1px solid var(--border);
  }

  .social-label {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--text-faint);
    margin-bottom: var(--space-8);
    line-height: 1;
  }

  .social-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
    border-top: 1px solid var(--border);
    max-width: 480px;
  }

  .social-link {
    display: flex;
    align-items: center;
    gap: var(--space-5);
    padding: var(--space-5) var(--space-3);
    border-bottom: 1px solid var(--border);
    border-left: 2px solid transparent;
    color: var(--text-muted);
    transition: all var(--duration-fast) var(--ease-out);
  }

  .social-link:hover {
    border-left-color: var(--accent);
    background-color: var(--bg-subtle);
    padding-left: var(--space-5);
    color: var(--text);
  }

  .social-icon {
    color: var(--text-faint);
    flex-shrink: 0;
    display: flex;
    align-items: center;
    transition: color var(--duration-fast) var(--ease-out);
  }

  .social-link:hover .social-icon {
    color: var(--accent);
  }

  .social-name {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--text);
    letter-spacing: 0.03em;
    flex-shrink: 0;
    min-width: 5rem;
  }

  .social-handle {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--text-faint);
    letter-spacing: 0.02em;
  }
</style>
