---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SectionLabel from '@/components/astro/SectionLabel.astro';
import TechTag from '@/components/astro/TechTag.astro';
import { Terminal, Shield, FlaskConical, Check } from '@lucide/astro';
import { site } from '@/data/site';

const philosophy = [
  {
    icon: Terminal,
    title: 'Kalite Mühendisliği',
    desc: 'Test, bir son adım değil — tasarımın parçası. Kaliteyi sürecin başına taşımak, son dakika düzeltmelerini ortadan kaldırır.',
  },
  {
    icon: FlaskConical,
    title: 'Veri Odaklı Karar',
    desc: 'Her test kararının arkasında ölçülebilir bir neden var. Metrikler, sezgiden daha güvenilir bir pusula.',
  },
  {
    icon: Shield,
    title: 'Sürdürülebilir Otomasyon',
    desc: 'Bakımı zor testler, hiç test olmamaktan kötüdür. Modüler, okunabilir ve evrililebilir mimariler yazıyorum.',
  },
];

const techStack = [
  {
    category: 'Test',
    items: ['Playwright', 'Vitest', 'Jest', 'Pact', 'Argos CI'],
  },
  {
    category: 'Diller',
    items: ['TypeScript', 'JavaScript', 'Python'],
  },
  {
    category: 'Tooling',
    items: ['GitHub Actions', 'Docker', 'k6', 'Allure', 'Grafana'],
  },
  {
    category: 'AI & ML',
    items: ['LLM Test Generation', 'Visual Regression AI', 'Prompt Engineering'],
  },
];

const values = [
  'Açık iletişim ve beklenti yönetimi',
  'Kodu ürüne dönüştüren mühendislik sahiplenişi',
  'Sürekli öğrenme ve paylaşma kültürü',
  'Basit, okunabilir ve test edilebilir kod',
  'Ekip içi güveni inşa eden şeffaf süreçler',
];
---

<BaseLayout
  title="Hakkımda"
  description={site.bio}
>
  <article class="about-page">
    <div class="container">

      <!-- ─── 01 // KİMLİK ─── -->
      <section class="about-section">
        <SectionLabel number="01" label="Kimlik" />
        <div class="identity-grid">
          <div class="identity-main">
            <h1 class="identity-name">{site.name}</h1>
            <p class="identity-role">{site.role}</p>
            <p class="identity-bio">{site.bio}</p>
          </div>
          <div class="identity-meta">
            <div class="meta-item">
              <span class="meta-label">Konum</span>
              <span class="meta-value">{site.location}</span>
            </div>
            <div class="meta-item">
              <span class="meta-label">Odak</span>
              <span class="meta-value">Playwright · TypeScript · AI Testing</span>
            </div>
            <div class="meta-item">
              <span class="meta-label">Durum</span>
              <span class="meta-value meta-value--accent">{site.now}</span>
            </div>
          </div>
        </div>
      </section>

      <!-- ─── 02 // MÜHENDİSLİK FELSEFESİ ─── -->
      <section class="about-section about-section--border">
        <SectionLabel number="02" label="Mühendislik Felsefesi" />
        <div class="philosophy-grid">
          {philosophy.map(({ icon: Icon, title, desc }, i) => (
            <div class="philosophy-card" data-reveal data-reveal-delay={String(i + 1) as "1" | "2" | "3"}>
              <div class="philosophy-icon">
                <Icon size={18} strokeWidth={1.5} />
              </div>
              <h3 class="philosophy-title">{title}</h3>
              <p class="philosophy-desc">{desc}</p>
            </div>
          ))}
        </div>
      </section>

      <!-- ─── 03 // YOLCULUK ─── -->
      <section class="about-section about-section--border">
        <SectionLabel number="03" label="Yolculuk" />
        <div class="journey-prose">
          <p>
            Yazılım kalitesiyle tanışmam, bir fintech şirketinde QA mühendisi olarak başladığım ilk işimde oldu.
            Manuel testlerin bir ekibi nasıl yıprattığını görmek, otomasyon alanına olan ilgimi şekillendirdi.
            O günden bu yana her projede "bu nasıl daha güvenilir hale gelir?" sorusunu sormaktan vazgeçmedim.
          </p>
          <p>
            Playwright'ı keşfettiğimde, tarayıcı testlerinin gerçekten iyi yazılabileceğini anladım.
            TypeScript ile birleşince, büyük ölçekte sürdürülebilir test altyapıları inşa etmek mümkün hale geldi.
            SaaS ve finans sektörlerinde çalıştığım projelerde bu ikiliyi derinlemesine kullandım.
          </p>
          <p>
            Son dönemde AI destekli test süreçleri beni heyecanlandırıyor.
            LLM'lerin test üretimine, görsel regresyon analizine ve akıllı bakım süreçlerine kattığı değeri araştırıyorum.
            Öğrendiklerimi blog yazıları ve açık kaynak projelerle paylaşmaya çalışıyorum.
          </p>
        </div>
      </section>

      <!-- ─── 04 // TEKNİK STACK ─── -->
      <section class="about-section about-section--border">
        <SectionLabel number="04" label="Teknik Stack" />
        <div class="stack-grid">
          {techStack.map((group) => (
            <div class="stack-group">
              <h3 class="stack-category">{group.category}</h3>
              <div class="stack-tags">
                {group.items.map((item) => <TechTag label={item} />)}
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- ─── 05 // ÇALIŞMA DEĞERLERİM ─── -->
      <section class="about-section about-section--border">
        <SectionLabel number="05" label="Çalışma Değerlerim" />
        <ul class="values-list">
          {values.map((value, i) => (
            <li class="values-item" data-reveal data-reveal-delay={String((i % 5) + 1) as "1" | "2" | "3" | "4" | "5"}>
              <span class="values-icon">
                <Check size={14} strokeWidth={2} />
              </span>
              <span class="values-text">{value}</span>
            </li>
          ))}
        </ul>
      </section>

      <!-- ─── CTA ─── -->
      <section class="about-cta">
        <a href="/iletisim" class="btn btn-primary">İletişime geç</a>
        <a href="/deneyim" class="btn btn-secondary">Deneyimim</a>
      </section>

    </div>
  </article>
</BaseLayout>

<style>
  .about-page {
    padding-block: var(--space-12) var(--space-section-mobile);
  }

  @media (min-width: 1024px) {
    .about-page {
      padding-block: var(--space-12) var(--space-section-desktop);
    }
  }

  .about-section {
    margin-bottom: var(--space-16);
  }

  .about-section--border {
    padding-top: var(--space-12);
    border-top: 1px solid var(--border);
  }

  /* ─── Kimlik ─── */
  .identity-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-12);
    margin-top: var(--space-10);
    align-items: start;
  }

  @media (max-width: 768px) {
    .identity-grid {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }
  }

  .identity-name {
    font-size: clamp(2rem, 4vw + 0.5rem, 3rem);
    letter-spacing: var(--tracking-tight);
    line-height: var(--leading-tight);
    color: var(--text);
    margin-bottom: var(--space-3);
  }

  .identity-role {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: var(--space-6);
    line-height: 1;
  }

  .identity-bio {
    font-size: var(--text-lg);
    color: var(--text-muted);
    line-height: var(--leading-relaxed);
    max-width: 52ch;
  }

  .identity-meta {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    padding: var(--space-8);
    border: 1px solid var(--border);
    border-left: 2px solid var(--accent);
    border-radius: var(--radius-lg);
  }

  .meta-item { display: flex; flex-direction: column; gap: var(--space-2); }

  .meta-label {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--text-faint);
    line-height: 1;
  }

  .meta-value {
    font-size: var(--text-sm);
    color: var(--text-muted);
    line-height: var(--leading-relaxed);
  }

  .meta-value--accent {
    color: var(--text);
  }

  /* ─── Felsefe ─── */
  .philosophy-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
    margin-top: var(--space-10);
  }

  @media (max-width: 768px) {
    .philosophy-grid {
      grid-template-columns: 1fr;
    }
  }

  .philosophy-card {
    padding: var(--space-8);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
  }

  .philosophy-icon {
    color: var(--accent);
    margin-bottom: var(--space-5);
  }

  .philosophy-title {
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--text);
    margin-bottom: var(--space-3);
  }

  .philosophy-desc {
    font-size: var(--text-sm);
    color: var(--text-muted);
    line-height: var(--leading-relaxed);
  }

  /* ─── Yolculuk ─── */
  .journey-prose {
    margin-top: var(--space-10);
    max-width: 68ch;
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .journey-prose p {
    font-size: var(--text-base);
    color: var(--text-muted);
    line-height: var(--leading-loose);
  }

  /* ─── Stack ─── */
  .stack-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-8);
    margin-top: var(--space-10);
  }

  @media (max-width: 640px) {
    .stack-grid {
      grid-template-columns: 1fr;
    }
  }

  .stack-group { display: flex; flex-direction: column; gap: var(--space-4); }

  .stack-category {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--text-faint);
    line-height: 1;
  }

  .stack-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  /* ─── Değerler ─── */
  .values-list {
    list-style: none;
    padding: 0;
    margin-top: var(--space-10);
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    max-width: 56ch;
  }

  .values-item {
    display: flex;
    align-items: flex-start;
    gap: var(--space-4);
  }

  .values-icon {
    color: var(--accent);
    flex-shrink: 0;
    margin-top: 2px;
  }

  .values-text {
    font-size: var(--text-base);
    color: var(--text-muted);
    line-height: var(--leading-relaxed);
  }

  /* ─── CTA ─── */
  .about-cta {
    padding-top: var(--space-12);
    border-top: 1px solid var(--border);
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
  }
</style>
