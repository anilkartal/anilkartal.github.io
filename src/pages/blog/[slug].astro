---
import PostLayout from '@/layouts/PostLayout.astro';
import { getCollection } from 'astro:content';
import { render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);

// Yaklaşık okuma süresi
const wordCount = post.body?.trim().split(/\s+/).length ?? 0;
const readingMins = Math.ceil(wordCount / 200);
const readingTime = `${readingMins} dk okuma`;

// İlgili yazılar: aynı kategoriden, bu yazı hariç
const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const relatedPosts = allPosts
  .filter((p) => p.id !== post.id && p.data.category === post.data.category)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 2)
  .map((p) => ({
    slug: p.id,
    title: p.data.title,
    category: p.data.category,
    date: p.data.date,
  }));
---

<PostLayout
  title={post.data.title}
  description={post.data.description}
  date={post.data.date}
  category={post.data.category}
  tags={post.data.tags}
  readingTime={readingTime}
  headings={headings}
  relatedPosts={relatedPosts}
>
  <Content />
</PostLayout>
