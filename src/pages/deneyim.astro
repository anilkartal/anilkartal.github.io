---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SectionLabel from '@/components/astro/SectionLabel.astro';
import TechTag from '@/components/astro/TechTag.astro';
import {
  Terminal,
  Brain,
  Shield,
  ChevronRight,
  Layers,
  GitBranch,
  Users,
  BadgeCheck,
  Cpu,
} from '@lucide/astro';
import { site } from '@/data/site';

const philosophy = [
  {
    icon: Shield,
    label: '01. TEST GÜVEN ÜRETİR',
    text: 'Test süreçlerinin amacı yalnızca hata bulmak değil, yazılımın üretim ortamındaki davranışına güven oluşturmaktır. Hızlı çalışan ama güven vermeyen testler sürdürülebilir değildir.',
  },
  {
    icon: Layers,
    label: '02. SÜRDÜRÜLEBİLİR MİMARİ',
    text: 'Uzun ömürlü kalite sistemleri; düşük bakım maliyeti, okunabilir yapı ve sürdürülebilir otomasyon yaklaşımıyla inşa edilir. Test kodu da mühendislik disiplininin bir parçasıdır.',
  },
  {
    icon: BadgeCheck,
    label: '03. ÖLÇÜLEBİLİR KALİTE',
    text: 'Ölçülemeyen kalite geliştirilemez. Metrikler, test coverage ve kalite sinyalleri daha güvenilir mühendislik kararları için temel veri kaynaklarıdır.',
  },
  {
    icon: Cpu,
    label: '04. YAPAY ZEKA DESTEKLİ KALİTE GÜVENCESİ',
    text: 'Yapay zeka, QA mühendisinin yerini almak yerine çalışma biçimini dönüştürüyor. Tekrarlayan operasyonları azaltırken, mühendislik düşüncesini daha değerli hale getiriyor.',
  },
];

const timeline = [
  {
    period: '2026 — Günümüz',
    role: 'Software Test and Quality Expert',
    company: '[Havacılık Sektörü]',
    description: 'Kurumsal ölçekte geliştirilen yazılım sistemlerinde kalite süreçleri, test operasyonları ve güvenilir release akışları üzerine çalışıyorum. Kritik iş süreçlerinde sürdürülebilir kalite yaklaşımı ve modern test mühendisliği pratiklerine odaklanıyorum.',
    achievements: [],
    tags: [],
  },
  {
    period: '2021 — 2022',
    role: 'Senior Software Test and Quality',
    company: '[V-Ticaret Platformu]',
    description: 'E-ticaret odaklı uygulamalarda kullanıcı deneyimi, sipariş süreçleri ve ödeme akışlarının kalite kontrolü üzerine çalışarak uçtan uca test süreçlerine katkı sağladım.',
    achievements: [],
    tags: [],
  },
  {
    period: '2019 — 2021',
    role: 'Senior Software Test and Quality',
    company: '[Sağlık Bakanlığı · İK & Maaş Sistemleri]',
    description: 'Kamu ölçekli insan kaynakları ve maaş yönetim sistemlerinde kalite süreçlerinin yönetimi, test senaryolarının analizi ve iş kritik akışların doğrulanması üzerine çalıştım.',
    achievements: [],
    tags: [],
  },
  {
    period: '2014 — 2019',
    role: 'Senior Software Test and Quality',
    company: '[ERP Sistemleri]',
    description: 'Yazılım kalite yolculuğuma ERP projelerinde başladım. İş süreçlerinin karmaşıklığı, veri doğruluğu ve operasyonel güvenilirlik üzerine çalışarak kalite mühendisliği yaklaşımımın temelini bu dönemde oluşturdum.',
    achievements: [],
    tags: [],
  },
];

const expertiseClusters = [
  {
    id: 'core',
    title: 'Core Automation',
    colSpan: 2,
    icon: Layers,
    subSkills: [
      { label: 'WEB E2E', level: 'UZMAN', width: 92, tools: 'Playwright, Cypress, Selenium' },
      { label: 'MOBİL', level: 'İLERİ', width: 75, tools: 'Appium, Espresso, XCUITest' },
      { label: 'API & PERF', level: 'UZMAN', width: 88, tools: 'k6, Postman, Playwright API' },
    ],
  },
  {
    id: 'ai',
    title: 'AI & İnovasyon',
    colSpan: 1,
    icon: Brain,
    description: 'LLM tabanlı test senaryosu üretimi ve AI destekli görsel regresyon testleri. Geleneksel assertion\'ların kaçırdığı anomalileri tespit eden heuristik analiz.',
  },
  {
    id: 'cicd',
    title: 'CI/CD & Altyapı',
    colSpan: 1,
    icon: GitBranch,
    description: 'GitHub Actions, Docker, Kubernetes. Katı quality gate\'ler ve otomatik rollback mekanizmaları içeren dayanıklı pipeline mimarisi.',
  },
  {
    id: 'culture',
    title: 'Kültür & Liderlik',
    colSpan: 2,
    icon: Users,
    description: '"Quality First" zihniyetini ekiplere yerleştirme. Playwright eğitimleri, pair testing seansları ve mühendislik verimliliği kültürü oluşturma üzerine odaklanma.',
  },
];

const certifications = [
  {
    name: 'ISTQB® Certified Tester Foundation Level (CTFL)',
    url: 'https://app.diplomasafe.com/en-US/diploma/d55a032f39de584b8f17db9442f5a64dad69c33bf',
    image: '/ISTQBsertifika.png',
  },
];
---

<BaseLayout
  title="Deneyim"
  description="Kariyer yolculuğu, teknik uzmanlıklar, eğitim ve sertifikalar."
>
  <div class="deneyim-page">

    <!-- 01 // KİMLİK -->
    <section class="section identity-section">
      <div class="container">
        <div class="identity-grid">
          <div class="identity-left">
            <SectionLabel number="01" label="Kimlik" />
            <h1 class="identity-title">
              Modern kalite mühendisliği ve AI destekli test sistemleri üzerine çalışıyorum.
            </h1>
            <p class="identity-bio">
              10+ yıllık kalite mühendisliği deneyimimi ERP, e-ticaret, kamu ve kurumsal projelerde edindiğim saha tecrübesiyle birleştiriyorum. Manuel test süreçlerinden sürdürülebilir otomasyon mimarilerine uzanan bu yolculukta, odağımı güven üreten kalite sistemleri ve modern AI-assisted QA yaklaşımlarına taşıyorum.
            </p>
            <p class="identity-bio">
              Bugün özellikle quality engineering, sürdürülebilir test altyapıları ve yapay zeka destekli test süreçleri üzerine çalışıyorum.
            </p>
          </div>

          <div class="philosophy-card">
            <h2 class="philosophy-title">QA Felsefesi</h2>
            <ul class="philosophy-list">
              {philosophy.map(({ icon: Icon, label, text }) => (
                <li class="philosophy-item">
                  <div class="philosophy-icon">
                    <Icon size={20} strokeWidth={1.5} />
                  </div>
                  <div>
                    <p class="philosophy-item-label">{label}</p>
                    <p class="philosophy-item-text">{text}</p>
                  </div>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- 02 // YOLCULUK -->
    <section class="section timeline-section">
      <div class="container">
        <SectionLabel number="02" label="Yolculuk" />
        <h2 class="section-title">Profesyonel Yolculuk</h2>

        <div class="timeline">
          <div class="timeline-line" aria-hidden="true"></div>

          {timeline.map((entry, i) => (
            <div class={`timeline-entry ${i % 2 === 0 ? 'is-right' : 'is-left'}`} data-reveal data-reveal-delay={String(i + 1) as "1" | "2" | "3"}>
              <!-- Yıl etiketi -->
              <div class="timeline-period">
                <span class="timeline-period-text">{entry.period}</span>
              </div>

              <!-- Merkez nokta -->
              <div class="timeline-dot" aria-hidden="true"></div>

              <!-- Kart -->
              <div class="timeline-card">
                <div class="timeline-card-header">
                  <p class="timeline-role">{entry.role}</p>
                  <p class="timeline-company">{entry.company}</p>
                </div>
                <p class="timeline-desc">{entry.description}</p>
                {entry.achievements.length > 0 && (
                  <ul class="timeline-achievements">
                    {entry.achievements.map((a) => (
                      <li class="timeline-achievement">
                        <ChevronRight size={13} strokeWidth={2} class="timeline-chevron" />
                        <span>{a}</span>
                      </li>
                    ))}
                  </ul>
                )}
                {entry.tags.length > 0 && (
                  <div class="timeline-tags">
                    {entry.tags.map((t) => <TechTag label={t} />)}
                  </div>
                )}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- 03 // ŞU ANDA ARAŞTIRIYORUM -->
    <section class="section research-section">
      <div class="container">
        <SectionLabel number="03" label="Araştırma" />
        <h2 class="section-title">Şu Anda Araştırıyorum</h2>
        <ul class="research-list">
          <li class="research-item">
            <div class="research-icon"><Brain size={18} strokeWidth={1.5} /></div>
            <span>Yapay Zeka Destekli Test İş Akışları</span>
          </li>
          <li class="research-item">
            <div class="research-icon"><Layers size={18} strokeWidth={1.5} /></div>
            <span>Sürdürülebilir Otomasyon Stratejileri</span>
          </li>
          <li class="research-item">
            <div class="research-icon"><Cpu size={18} strokeWidth={1.5} /></div>
            <span>Yapay Zeka ile Mühendislik Verimliliği</span>
          </li>
        </ul>
      </div>
    </section>

    <!-- 04 // SERTİFİKALAR -->
    <section class="section credentials-section">
      <div class="container">
        <SectionLabel number="04" label="Sertifikalar" />
        <ul class="cert-list">
          {certifications.map((cert) => (
            <li class="cert-item">
              <a
                href={cert.url}
                target="_blank"
                rel="noopener noreferrer"
                class="cert-link"
              >
                <span class="cert-name">{cert.name}</span>
                <BadgeCheck size={16} strokeWidth={1.5} class="cert-check" />
              </a>
              {cert.image && (
                <a
                  href={cert.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="cert-preview"
                  aria-label={`${cert.name} — sertifikayı doğrula`}
                >
                  <img
                    src={cert.image}
                    alt={`${cert.name} sertifikası`}
                    class="cert-preview-img"
                    loading="lazy"
                    decoding="async"
                  />
                  <span class="cert-preview-overlay">
                    <BadgeCheck size={20} strokeWidth={1.5} />
                    Doğrula
                  </span>
                </a>
              )}
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- 05 // UZMANLIKLAR -->
    <section class="section expertise-section">
      <div class="container">
        <SectionLabel number="05" label="Uzmanlıklar" />
        <h2 class="section-title">Uzmanlık Alanları</h2>

        <div class="expertise-grid">
          {expertiseClusters.map((cluster, i) => (
            <div data-reveal data-reveal-delay={String((i % 4) + 1) as "1" | "2" | "3" | "4"}
              class={`expertise-card ${cluster.colSpan === 2 ? 'expertise-card--wide' : ''}`}
            >
              <div class="expertise-card-header">
                <div class="expertise-icon">
                  <cluster.icon size={20} strokeWidth={1.5} />
                </div>
                <h3 class="expertise-card-title">{cluster.title}</h3>
              </div>

              {cluster.subSkills ? (
                <div class="skill-grid">
                  {cluster.subSkills.map((skill) => (
                    <div class="skill-item">
                      <div class="skill-item-header">
                        <span class="skill-label">{skill.label}</span>
                        <span class="skill-badge">{skill.level}</span>
                      </div>
                      <div class="skill-bar" role="presentation">
                        <div class="skill-bar-fill" style={`width: ${skill.width}%`}></div>
                      </div>
                      <p class="skill-tools">{skill.tools}</p>
                    </div>
                  ))}
                </div>
              ) : (
                <p class="expertise-desc">{cluster.description}</p>
              )}
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Alt CTA -->
    <section class="section cta-section">
      <div class="container">
        <div class="cta-inner">
          <p class="cta-label">
            <span class="cta-accent">// </span>İletişim
          </p>
          <h2 class="cta-title">Güvenilir sistemler sürdürülebilir test mimarileriyle inşa edilir.</h2>
          <p class="cta-sub">
            Quality engineering, sürdürülebilir test mimarileri ve AI-assisted QA süreçleri üzerine çalışıyorum.
          </p>
          <p class="cta-sub">
            Modern yazılım sistemlerinde güvenilir kalite yaklaşımı hakkında konuşmak veya fikir alışverişi yapmak isterseniz iletişime geçebilirsiniz.
          </p>
          <div class="cta-actions">
            <a href="/iletisim" class="btn btn-primary">İLETİŞİM</a>
            <a
              href={site.social.linkedin}
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn-secondary"
            >
              LINKEDIN'DE BAĞLAN
            </a>
          </div>
        </div>
      </div>
    </section>

  </div>
</BaseLayout>

<style>
  /* ─── Genel ─── */
  .section-title {
    font-size: var(--text-3xl);
    letter-spacing: var(--tracking-tight);
    color: var(--text);
    margin-top: var(--space-3);
    margin-bottom: var(--space-12);
    line-height: var(--leading-snug);
  }

  /* ─── 01 KİMLİK ─── */
  .identity-section {
    padding-top: var(--space-12);
  }

  .identity-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-12);
    align-items: start;
  }

  @media (min-width: 1024px) {
    .identity-grid {
      grid-template-columns: 1fr 420px;
      gap: var(--space-16);
    }
  }

  .identity-title {
    font-size: clamp(1.375rem, 2vw + 0.5rem, 1.75rem);
    letter-spacing: var(--tracking-tight);
    line-height: var(--leading-snug);
    color: var(--text);
    margin-top: var(--space-2);
    margin-bottom: var(--space-6);
  }

  .identity-bio {
    font-size: var(--text-base);
    color: var(--text-muted);
    line-height: var(--leading-relaxed);
    max-width: 52ch;
  }

  .identity-bio + .identity-bio {
    margin-top: var(--space-5);
  }

  /* Felsefe kartı */
  .philosophy-card {
    border: 1px solid var(--border);
    border-left: 1px solid var(--accent);
    border-radius: var(--radius-lg);
    padding: var(--space-8);
    background-color: var(--bg-subtle);
  }

  .philosophy-title {
    font-size: var(--text-lg);
    font-weight: 600;
    letter-spacing: var(--tracking-tight);
    color: var(--text);
    margin-bottom: var(--space-8);
  }

  .philosophy-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .philosophy-item {
    display: flex;
    gap: var(--space-4);
    align-items: flex-start;
    padding-block: var(--space-6);
    border-bottom: 1px solid var(--border);
  }

  .philosophy-item:first-child {
    padding-top: 0;
  }

  .philosophy-item:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .philosophy-icon {
    flex-shrink: 0;
    color: var(--accent);
    margin-top: 2px;
  }

  .philosophy-item-label {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: var(--space-2);
    line-height: 1;
  }

  .philosophy-item-text {
    font-size: var(--text-sm);
    color: var(--text-muted);
    line-height: var(--leading-relaxed);
  }

  /* ─── 02 TIMELINE ─── */
  .timeline-section {
    padding-top: var(--space-section-mobile);
  }

  @media (min-width: 1024px) {
    .timeline-section {
      padding-top: var(--space-section-desktop);
    }
  }

  .timeline {
    position: relative;
    padding-block: var(--space-8) var(--space-4);
  }

  /* Merkez dikey çizgi — sadece desktop */
  .timeline-line {
    display: none;
  }

  @media (min-width: 1024px) {
    .timeline-line {
      display: block;
      position: absolute;
      left: 50%;
      top: 0;
      bottom: 0;
      width: 1px;
      background-color: var(--border);
      transform: translateX(-50%);
    }
  }

  /* Timeline entry */
  .timeline-entry {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    margin-bottom: var(--space-12);
    padding-left: var(--space-8);
  }

  .timeline-entry:last-child {
    margin-bottom: 0;
  }

  @media (min-width: 1024px) {
    .timeline-entry {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0 var(--space-12);
      align-items: start;
      padding-left: 0;
    }
  }

  /* Nokta */
  .timeline-dot {
    position: absolute;
    left: -5px;
    top: var(--space-2);
    width: 10px;
    height: 10px;
    background-color: var(--accent);
    border: 2px solid var(--bg);
    border-radius: 50%;
    flex-shrink: 0;
  }

  @media (min-width: 1024px) {
    .timeline-dot {
      left: 50%;
      top: var(--space-3);
      transform: translateX(-50%);
      width: 12px;
      height: 12px;
      grid-column: 1 / -1;
      position: absolute;
    }
  }

  /* Dönem etiketi */
  .timeline-period {
    order: -1;
  }

  .timeline-period-text {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--accent);
    letter-spacing: 0.06em;
    line-height: 1;
  }

  @media (min-width: 1024px) {
    .timeline-entry.is-right .timeline-period {
      grid-column: 1;
      text-align: right;
      padding-right: calc(var(--space-12) / 2 + 8px);
      padding-top: var(--space-3);
      order: 0;
    }

    .timeline-entry.is-right .timeline-card {
      grid-column: 2;
      padding-left: calc(var(--space-12) / 2 + 8px);
    }

    .timeline-entry.is-left .timeline-period {
      grid-column: 2;
      text-align: left;
      padding-left: calc(var(--space-12) / 2 + 8px);
      padding-top: var(--space-3);
      order: 1;
    }

    .timeline-entry.is-left .timeline-card {
      grid-column: 1;
      padding-right: calc(var(--space-12) / 2 + 8px);
      order: 0;
    }
  }

  /* Kart */
  .timeline-card {
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: var(--space-8) var(--space-7);
    background-color: var(--bg);
    transition: border-color var(--duration-fast) var(--ease-out),
                background-color var(--duration-fast) var(--ease-out);
  }

  .timeline-card:hover {
    border-color: var(--border-strong);
    background-color: var(--bg-subtle);
  }

  .timeline-card-header {
    margin-bottom: var(--space-4);
  }

  .timeline-role {
    font-size: var(--text-lg);
    font-weight: 600;
    letter-spacing: var(--tracking-tight);
    color: var(--text);
    margin-bottom: var(--space-2);
    line-height: var(--leading-snug);
  }

  .timeline-company {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--text-faint);
    letter-spacing: 0.06em;
  }

  .timeline-desc {
    font-size: var(--text-sm);
    color: var(--text-muted);
    line-height: var(--leading-relaxed);
    margin-bottom: 0;
  }

  .timeline-achievements {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    margin-top: var(--space-5);
    margin-bottom: var(--space-5);
  }

  .timeline-achievement {
    display: flex;
    align-items: flex-start;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: var(--text-muted);
    line-height: var(--leading-relaxed);
  }

  .timeline-chevron {
    flex-shrink: 0;
    color: var(--accent);
    margin-top: 3px;
  }

  .timeline-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-top: var(--space-4);
  }

  /* ─── 03 ŞU ANDA ARAŞTIRIYORUM ─── */
  .research-section {
    padding-top: var(--space-section-mobile);
  }

  @media (min-width: 1024px) {
    .research-section {
      padding-top: var(--space-section-desktop);
    }
  }

  .research-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    max-width: 560px;
  }

  .research-item {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-5) var(--space-6);
    border: 1px solid var(--border);
    border-left: 2px solid var(--accent);
    border-radius: var(--radius-lg);
    background-color: var(--bg-subtle);
    font-size: var(--text-base);
    color: var(--text-muted);
    transition: border-color var(--duration-fast) var(--ease-out),
                background-color var(--duration-fast) var(--ease-out);
  }

  .research-item:hover {
    border-color: var(--accent);
    background-color: var(--bg);
  }

  .research-icon {
    flex-shrink: 0;
    color: var(--accent);
  }

  /* ─── 05 UZMANLIKLAR ─── */
  .expertise-section {
    padding-top: var(--space-section-mobile);
  }

  @media (min-width: 1024px) {
    .expertise-section {
      padding-top: var(--space-section-desktop);
    }
  }

  .expertise-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-5);
  }

  @media (min-width: 768px) {
    .expertise-grid {
