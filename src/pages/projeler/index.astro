---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SectionLabel from '@/components/astro/SectionLabel.astro';
import TechTag from '@/components/astro/TechTag.astro';
import { getCollection } from 'astro:content';

const allProjects = (await getCollection('projects', ({ data }) => !data.draft))
  .sort((a, b) => a.data.order - b.data.order || b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout
  title="AI Projeleri"
  description="Yapay zeka araçları, LLM entegrasyonları ve otomasyon deneyleri — keşfettiğim, inşa ettiğim ve öğrendiğim her şey."
>
  <section class="projects-page section">
    <div class="container">

      <SectionLabel number="00" label="AI Projeleri" />
      <h1 class="projects-title">Yapay Zeka ile İnşa Ettiklerim</h1>
      <p class="projects-sub">
        LLM entegrasyonlarından otomasyon araçlarına, deney niteliğindeki prototiplerden gerçek kullanım senaryolarına — yapay zeka alanında keşfettiğim ve ürettiğim çalışmalar.
      </p>

      <!-- Proje listesi -->
      <ul class="project-list">
        {allProjects.map((project, i) => (
          <li class="project-row">
            <a href={`/projeler/${project.id}`} class="project-link">
              <div class="project-link__left">
                <span class="project-index">{String(i + 1).padStart(2, '0')}</span>
                <div class="project-info">
                  <div class="project-meta-row">
                    <span class="project-year">{project.data.year}</span>
                    <span class="project-role">{project.data.role}</span>
                  </div>
                  <h2 class="project-title">{project.data.title}</h2>
                  <p class="project-desc">{project.data.description}</p>
                </div>
              </div>
              <div class="project-tags">
                {project.data.technologies.slice(0, 4).map((tech) => (
                  <TechTag label={tech} />
                ))}
                {project.data.technologies.length > 4 && (
                  <span class="project-tags-more">+{project.data.technologies.length - 4}</span>
                )}
              </div>
            </a>
          </li>
        ))}
      </ul>

    </div>
  </section>
</BaseLayout>

<style>
  .projects-title {
    font-size: clamp(2rem, 4vw + 0.5rem, 3.5rem);
    letter-spacing: var(--tracking-tight);
    color: var(--text);
    margin-top: var(--space-3);
    margin-bottom: var(--space-5);
  }

  .projects-sub {
    font-size: var(--text-lg);
    color: var(--text-muted);
    max-width: 52ch;
    margin-bottom: var(--space-12);
    line-height: var(--leading-relaxed);
  }

  /* Liste */
  .project-list {
    list-style: none;
    padding: 0;
    margin: 0;
    border-top: 1px solid var(--border);
  }

  .project-row {
    border-bottom: 1px solid var(--border);
  }

  .project-link {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-8);
    padding: var(--space-8) var(--space-3);
    border-left: 2px solid transparent;
    transition: border-color var(--duration-fast) var(--ease-out),
                background-color var(--duration-fast) var(--ease-out),
                padding-left var(--duration-fast) var(--ease-out);
  }

  .project-link:hover {
    border-left-color: var(--accent);
    background-color: var(--bg-subtle);
    padding-left: var(--space-5);
  }

  /* Sol taraf */
  .project-link__left {
    display: flex;
    align-items: flex-start;
    gap: var(--space-6);
    flex: 1;
    min-width: 0;
  }

  .project-index {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--text-faint);
    letter-spacing: 0.08em;
    flex-shrink: 0;
    margin-top: 3px;
    line-height: 1;
  }

  .project-info {
    flex: 1;
    min-width: 0;
  }

  .project-meta-row {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-3);
  }

  .project-year {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--accent);
    letter-spacing: 0.06em;
    line-height: 1;
  }

  .project-role {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--text-faint);
    letter-spacing: 0.03em;
    line-height: 1;
  }

  .project-title {
    font-size: var(--text-xl);
    font-weight: 600;
    letter-spacing: var(--tracking-tight);
    color: var(--text);
    margin-bottom: var(--space-3);
    line-height: var(--leading-snug);
    transition: color var(--duration-fast) var(--ease-out);
  }

  .project-link:hover .project-title {
    color: var(--accent);
  }

  .project-desc {
    font-size: var(--text-sm);
    color: var(--text-muted);
    line-height: var(--leading-relaxed);
    max-width: 64ch;
  }

  /* Etiketler */
  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    align-items: flex-start;
    flex-shrink: 0;
    padding-top: 3px;
  }

  .project-tags-more {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--text-faint);
    line-height: 1;
    align-self: center;
  }

  /* Mobile */
  @media (max-width: 768px) {
    .project-link {
      flex-direction: column;
      gap: var(--space-5);
    }

    .project-tags {
      padding-top: 0;
    }
  }

  @media (max-width: 640px) {
    .project-link__left {
      gap: var(--space-4);
    }

    .project-index {
      display: none;
    }
  }
</style>
